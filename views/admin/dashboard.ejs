<%- include('../partials/header') %>

<div class="container page-wrapper">
    <div class="dash-layout">

        <!-- Sidebar -->
        <aside class="sidebar animate-fade">
            <div class="sidebar-avatar">
                <div class="avatar" style="background:linear-gradient(135deg,#ef4444,#f97316);">A</div>
                <h4>Administrator</h4>
                <p>Admin Panel</p>
            </div>
            <nav>
                <ul>
                    <li><a href="/admin/dashboard" class="active"><i class="fas fa-chart-bar"></i> Dashboard</a></li>
                    <li><a href="/admin/manage-events"><i class="fas fa-calendar-check"></i> Manage Events</a></li>
                    <li><a href="/admin/create-event"><i class="fas fa-plus-circle"></i> Create Event</a></li>
                    <li><a href="/admin/manage-users"><i class="fas fa-users"></i> Manage Users</a></li>
                    <li><a href="/logout" class="danger"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                </ul>
            </nav>
        </aside>

        <!-- Main Content -->
        <div>
            <div class="page-header">
                <h1>Admin Dashboard</h1>
                <a href="/admin/create-event" class="btn btn-primary"><i class="fas fa-plus"></i> Create Event</a>
            </div>

            <!-- Stats -->
            <div class="stat-grid">
                <div class="stat-card animate-fade">
                    <div class="stat-icon indigo"><i class="fas fa-calendar-check"></i></div>
                    <div class="stat-info"><h3><%= eventCount %></h3><p>Total Events</p></div>
                </div>
                <div class="stat-card animate-fade" style="animation-delay:0.1s;">
                    <div class="stat-icon cyan"><i class="fas fa-users"></i></div>
                    <div class="stat-info"><h3><%= userCount %></h3><p>Registered Users</p></div>
                </div>
                <div class="stat-card animate-fade" style="animation-delay:0.2s;">
                    <div class="stat-icon amber"><i class="fas fa-ticket-alt"></i></div>
                    <div class="stat-info"><h3><%= regCount %></h3><p>Active Registrations</p></div>
                </div>
                <div class="stat-card animate-fade" style="animation-delay:0.3s;">
                    <div class="stat-icon" style="background:rgba(239,68,68,0.15);color:#ef4444;"><i class="fas fa-hourglass-half"></i></div>
                    <div class="stat-info"><h3><%= pendingCount %></h3><p>Pending Approval</p></div>
                </div>
            </div>

            <!-- Recent Events Table -->
            <div class="table-card animate-fade">
                <div style="display:flex;justify-content:space-between;align-items:center;padding:18px 24px;border-bottom:1px solid var(--border);">
                    <h3 style="font-size:1rem;font-weight:700;">Recent Events</h3>
                    <a href="/admin/manage-events" class="btn btn-ghost" style="padding:7px 14px;font-size:0.8rem;">View All</a>
                </div>
                <table>
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Date</th>
                            <th>Approval</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (events.length === 0) { %>
                            <tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:30px;">No events yet.</td></tr>
                        <% } %>
                        <% events.forEach(function(event){ %>
                            <tr>
                                <td style="font-weight:600;"><%= event.title %></td>
                                <td style="color:var(--text-muted);"><%= event.category %></td>
                                <td style="color:var(--text-muted);font-size:0.85rem;"><%= event.date.toDateString() %></td>
                                <td>
                                    <span class="badge <%= event.status === 'approved' ? 'badge-approved' : 'badge-pending' %>">
                                        <%= event.status %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge" style="
                                        background: <%= event.eventStatus === 'Upcoming' ? 'rgba(6,182,212,0.15)' : event.eventStatus === 'Ongoing' ? 'rgba(245,158,11,0.15)' : 'rgba(100,116,139,0.15)' %>;
                                        color: <%= event.eventStatus === 'Upcoming' ? '#06b6d4' : event.eventStatus === 'Ongoing' ? '#f59e0b' : '#94a3b8' %>;">
                                        <%= event.eventStatus %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<%- include('../partials/footer') %>
