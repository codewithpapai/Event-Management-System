<%- include('../partials/header') %>

<div class="container page-wrapper">
    <div class="dash-layout">

        <!-- Sidebar -->
        <aside class="sidebar animate-fade">
            <div class="sidebar-avatar">
                <div class="avatar" style="background:linear-gradient(135deg,#ef4444,#f97316);">A</div>
                <h4>Administrator</h4>
                <p>Admin Panel</p>
            </div>
            <nav>
                <ul>
                    <li><a href="/admin/dashboard"><i class="fas fa-chart-bar"></i> Dashboard</a></li>
                    <li><a href="/admin/manage-events"><i class="fas fa-calendar-check"></i> Manage Events</a></li>
                    <li><a href="/admin/create-event"><i class="fas fa-plus-circle"></i> Create Event</a></li>
                    <li><a href="/admin/manage-users" class="active"><i class="fas fa-users"></i> Manage Users</a></li>
                    <li><a href="/logout" class="danger"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                </ul>
            </nav>
        </aside>

        <!-- Main -->
        <div>
            <div class="page-header">
                <h1>Manage Users</h1>
                <span style="font-size:0.875rem;color:var(--text-muted);"><%= users.length %> registered users</span>
            </div>

            <div class="table-card animate-fade" style="overflow-x:auto;">
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Joined</th>
                            <th>Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (users.length === 0) { %>
                            <tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:40px;">No users yet.</td></tr>
                        <% } %>
                        <% users.forEach(function(u, i){ %>
                            <tr>
                                <td style="color:var(--text-dim);"><%= i + 1 %></td>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <div style="width:34px;height:34px;border-radius:50%;background:var(--primary);display:flex;align-items:center;justify-content:center;font-size:0.85rem;font-weight:700;flex-shrink:0;">
                                            <%= u.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <span style="font-weight:600;"><%= u.name %></span>
                                    </div>
                                </td>
                                <td style="color:var(--text-muted);font-size:0.875rem;"><%= u.email %></td>
                                <td style="color:var(--text-muted);font-size:0.85rem;"><%= u.createdAt ? u.createdAt.toDateString() : 'N/A' %></td>
                                <td><span class="badge badge-user">User</span></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<%- include('../partials/footer') %>
