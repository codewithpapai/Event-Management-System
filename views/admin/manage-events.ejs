<%- include('../partials/header') %>

<div class="container page-wrapper">
    <div class="dash-layout">
        <aside class="sidebar animate-fade">
            <div class="sidebar-avatar">
                <div class="avatar" style="background:linear-gradient(135deg,#ef4444,#f97316);">A</div>
                <h4>Administrator</h4>
                <p>Admin Panel</p>
            </div>
            <nav>
                <ul>
                    <li><a href="/admin/dashboard"><i class="fas fa-chart-bar"></i> Dashboard</a></li>
                    <li><a href="/admin/manage-events" class="active"><i class="fas fa-calendar-check"></i> Manage Events</a></li>
                    <li><a href="/admin/create-event"><i class="fas fa-plus-circle"></i> Create Event</a></li>
                    <li><a href="/admin/manage-users"><i class="fas fa-users"></i> Manage Users</a></li>
                    <li><a href="/logout" class="danger"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                </ul>
            </nav>
        </aside>

        <div>
            <div class="page-header">
                <h1>Manage Events</h1>
                <a href="/admin/create-event" class="btn btn-primary"><i class="fas fa-plus"></i> Create Event</a>
            </div>

            <div class="table-card animate-fade" style="overflow-x:auto;">
                <table>
                    <thead>
                        <tr>
                            <th>Event</th>
                            <th>Category</th>
                            <th>Date</th>
                            <th>Seats</th>
                            <th>Approval</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (events.length === 0) { %>
                            <tr>
                                <td colspan="7" style="text-align:center;color:var(--text-muted);padding:40px;">
                                    No events yet. <a href="/admin/create-event" style="color:var(--primary);">Create one.</a>
                                </td>
                            </tr>
                        <% } %>
                        <% events.forEach(function(ev){ %>
                            <tr>
                                <td>
                                    <div style="font-weight:700;max-width:200px;"><%= ev.title %></div>
                                    <div style="font-size:0.75rem;color:var(--text-muted);margin-top:2px;">
                                        <i class="fas fa-map-marker-alt"></i> <%= ev.location %>
                                    </div>
                                </td>
                                <td style="font-size:0.85rem;"><%= ev.category %></td>
                                <td>
                                    <div style="font-size:0.85rem;"><%= ev.date.toDateString() %></div>
                                    <% if (ev.startTime) { %>
                                        <div style="font-size:0.75rem;color:var(--text-muted);">
                                            <i class="fas fa-clock"></i> <%= ev.startTime %><% if(ev.endTime){ %> &ndash; <%= ev.endTime %><% } %>
                                        </div>
                                    <% } %>
                                </td>
                                <td>
                                    <div style="font-size:0.85rem;font-weight:600;"><%= ev.maxSeats - ev.availableSeats %> / <%= ev.maxSeats %></div>
                                    <div style="font-size:0.75rem;color:var(--text-muted);">registered</div>
                                </td>
                                <td>
                                    <span class="badge <%= ev.status === 'approved' ? 'badge-approved' : 'badge-pending' %>">
                                        <%= ev.status %>
                                    </span>
                                </td>
                                <td>
                                    <% var bgColor = ev.eventStatus === 'Upcoming' ? 'rgba(6,182,212,0.15)' : ev.eventStatus === 'Ongoing' ? 'rgba(245,158,11,0.15)' : 'rgba(100,116,139,0.15)'; %>
                                    <% var txtColor = ev.eventStatus === 'Upcoming' ? '#06b6d4' : ev.eventStatus === 'Ongoing' ? '#f59e0b' : '#94a3b8'; %>
                                    <span class="badge" style="background:<%= bgColor %>;color:<%= txtColor %>;">
                                        <%= ev.eventStatus %>
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                                        <% if (ev.status === 'pending') { %>
                                            <a href="/admin/approve-event/<%= ev._id %>" class="action-btn approve" title="Approve Event">
                                                <i class="fas fa-check"></i>
                                            </a>
                                        <% } %>
                                        <a href="/admin/event-registrations/<%= ev._id %>" class="action-btn" title="View Registrations"
                                           style="color:var(--primary-light);background:rgba(99,102,241,0.1);">
                                            <i class="fas fa-users"></i>
                                        </a>
                                        <% var deleteUrl = '/admin/delete-event/' + ev._id; %>
                                        <% var deleteTitle = ev.title; %>
                                        <a href="#" class="action-btn delete" title="Delete Event"
                                           data-url="<%= deleteUrl %>" data-title="<%= deleteTitle %>"
                                           onclick="showDeleteConfirm(this.dataset.url, this.dataset.title); return false;">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
