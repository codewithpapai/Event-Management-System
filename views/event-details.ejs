<%- include('partials/header') %>

<div class="container page-wrapper">
    <div class="detail-grid">

        <!-- Left: Image + Badges -->
        <div>
            <img src="/uploads/<%= event.image %>" alt="<%= event.title %>" class="detail-img"
                 onerror="this.src='https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?auto=format&fit=crop&w=1200&q=80'">

            <div style="display:flex;gap:10px;margin-top:16px;flex-wrap:wrap;">
                <span class="badge" style="
                    font-size:0.8rem;padding:7px 14px;
                    background:<%= event.eventStatus === 'Upcoming' ? 'rgba(34,197,94,0.15)' : event.eventStatus === 'Ongoing' ? 'rgba(245,158,11,0.15)' : 'rgba(100,116,139,0.15)' %>;
                    color:<%= event.eventStatus === 'Upcoming' ? '#22c55e' : event.eventStatus === 'Ongoing' ? '#f59e0b' : '#94a3b8' %>;">
                    <i class="fas fa-circle" style="font-size:0.45rem;margin-right:4px;vertical-align:middle;"></i> <%= event.eventStatus %>
                </span>
                <span class="badge badge-user" style="font-size:0.8rem;padding:7px 14px;"><%= event.category %></span>
            </div>
        </div>

        <!-- Right: Info Card -->
        <div class="detail-info animate-fade">
            <h1 style="font-size:1.75rem;font-weight:800;letter-spacing:-0.5px;margin-bottom:8px;line-height:1.2;">
                <%= event.title %>
            </h1>
            <p style="color:var(--text-muted);font-size:0.9rem;line-height:1.8;margin-bottom:24px;">
                <%= event.description %>
            </p>

            <!-- Meta Info Grid -->
            <div class="detail-meta">
                <div class="meta-row">
                    <i class="far fa-calendar-alt"></i>
                    <strong><%= event.date.toDateString() %></strong>
                </div>

                <% if (event.startTime || event.endTime) { %>
                    <div class="meta-row">
                        <i class="fas fa-clock"></i>
                        <span>
                            <%= event.startTime ? event.startTime : '—' %>
                            <% if (event.endTime) { %> &nbsp;→&nbsp; <%= event.endTime %><% } %>
                        </span>
                    </div>
                <% } %>

                <% if (event.registrationDeadline) { %>
                    <div class="meta-row">
                        <i class="fas fa-hourglass-end" style="color:var(--warning);"></i>
                        <span>Registration Deadline: <strong><%= event.registrationDeadline.toDateString() %></strong></span>
                    </div>
                <% } %>

                <div class="meta-row">
                    <i class="fas fa-map-marker-alt"></i>
                    <span><%= event.location %></span>
                </div>

                <div class="meta-row">
                    <i class="fas fa-users"></i>
                    <span><strong><%= event.availableSeats %></strong> of <strong><%= event.maxSeats %></strong> seats available</span>
                </div>

                <% if (event.organizerName) { %>
                    <div class="meta-row">
                        <i class="fas fa-user-tie"></i>
                        <span>Organizer: <strong><%= event.organizerName %></strong></span>
                    </div>
                <% } %>

                <% if (event.speakerName) { %>
                    <div class="meta-row">
                        <i class="fas fa-microphone-alt"></i>
                        <span>Speaker: <strong><%= event.speakerName %></strong></span>
                    </div>
                <% } %>

                <% if (event.contactEmail) { %>
                    <div class="meta-row">
                        <i class="fas fa-envelope"></i>
                        <a href="mailto:<%= event.contactEmail %>" style="color:var(--primary-light);">
                            <%= event.contactEmail %>
                        </a>
                    </div>
                <% } %>

                <% if (event.contactPhone) { %>
                    <div class="meta-row">
                        <i class="fas fa-phone"></i>
                        <span><%= event.contactPhone %></span>
                    </div>
                <% } %>
            </div>

            <!-- Action Buttons — Admin sees ONLY info, no Register button -->
            <% if (typeof admin !== 'undefined' && admin && admin.username) { %>
                <!-- Admin View -->
                <div style="background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.15);border-radius:10px;padding:16px 20px;">
                    <p style="font-size:0.875rem;color:var(--primary-light);font-weight:600;margin-bottom:10px;">
                        <i class="fas fa-shield-alt"></i> Admin View
                    </p>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;">
                        <a href="/admin/event-registrations/<%= event._id %>" class="btn btn-primary" style="flex:1;min-width:140px;">
                            <i class="fas fa-users"></i> View Registrations (<%= event.maxSeats - event.availableSeats %>)
                        </a>
                        <a href="/admin/manage-events" class="btn btn-ghost" style="flex:1;min-width:140px;">
                            <i class="fas fa-arrow-left"></i> Back to Events
                        </a>
                    </div>
                </div>

            <% } else if (typeof user !== 'undefined' && user && user.name) { %>
                <!-- User View -->
                <% if (isRegistered) { %>
                    <div style="background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);color:#4ade80;padding:12px 16px;border-radius:10px;margin-bottom:14px;font-size:0.875rem;text-align:center;font-weight:600;">
                        <i class="fas fa-check-circle"></i> You are registered for this event!
                    </div>
                    <form action="/events/<%= event._id %>/cancel" method="POST">
                        <button type="submit" class="btn btn-danger" style="width:100%;padding:14px;">
                            <i class="fas fa-times-circle"></i> Cancel My Registration
                        </button>
                    </form>

                <% } else if (event.availableSeats > 0 && event.eventStatus !== 'Completed') { %>
                    <form action="/events/<%= event._id %>/register" method="POST">
                        <button type="submit" class="btn btn-primary" style="width:100%;padding:14px;font-size:1rem;">
                            <i class="fas fa-check-circle"></i> Register for Event
                        </button>
                    </form>

                <% } else { %>
                    <button class="btn" style="width:100%;padding:14px;background:var(--bg-input);color:var(--text-dim);cursor:not-allowed;border:1px solid var(--border);" disabled>
                        <i class="fas fa-ban"></i>
                        <%= event.eventStatus === 'Completed' ? 'Event Has Ended' : 'No Seats Available' %>
                    </button>
                <% } %>

                <a href="/events" style="display:block;text-align:center;margin-top:14px;font-size:0.85rem;color:var(--text-muted);">
                    <i class="fas fa-arrow-left"></i> Back to Events
                </a>

            <% } else { %>
                <!-- Guest View -->
                <a href="/login" class="btn btn-primary" style="width:100%;padding:14px;font-size:1rem;">
                    <i class="fas fa-sign-in-alt"></i> Login to Register
                </a>
            <% } %>

        </div>
    </div>
</div>

<%- include('partials/footer') %>
