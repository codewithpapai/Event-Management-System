<%- include('partials/header') %>

<div class="container page-wrapper">
    <div class="dash-layout">

        <aside class="sidebar animate-fade">
            <div class="sidebar-avatar">
                <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
                <h4><%= user.name %></h4>
                <p><%= user.email %></p>
            </div>
            <nav>
                <ul>
                    <li><a href="/dashboard"><i class="fas fa-ticket-alt"></i> My Registrations</a></li>
                    <li><a href="/user/profile" class="active"><i class="fas fa-user-edit"></i> Edit Profile</a></li>
                    <li><a href="/events"><i class="fas fa-search"></i> Browse Events</a></li>
                    <li><a href="/logout" class="danger"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                </ul>
            </nav>
        </aside>

        <div>
            <div class="page-header"><h1>Edit Profile</h1></div>

            <div class="card animate-fade" style="padding:36px;max-width:520px;">
                <form action="/user/profile" method="POST">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="name" value="<%= user.name %>" required>
                    </div>
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" name="email" value="<%= user.email %>" required>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:100%;padding:14px;">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

<%- include('partials/footer') %>
