<%- include('partials/header') %>

<div class="hero">
    <div class="container">
        <h1>Your College's<br><span style="background:linear-gradient(135deg,#6366f1,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Official Event Hub</span></h1>
        <p>Discover workshops, seminars, cultural fests, and more. Register for events and never miss what's happening on campus.</p>
        <div class="hero-actions">
            <% if (typeof user !== 'undefined' && user && user.name) { %>
                <a href="/events" class="btn btn-primary" style="padding:14px 36px;font-size:1rem;">Browse Events</a>
                <a href="/events/create" class="btn btn-ghost" style="padding:14px 36px;font-size:1rem;">Organize Event</a>
            <% } else { %>
                <a href="/login"    class="btn btn-primary" style="padding:14px 36px;font-size:1rem;">Get Started</a>
                <a href="/register" class="btn btn-ghost"   style="padding:14px 36px;font-size:1rem;">Create Account</a>
            <% } %>
        </div>
    </div>
</div>

<div class="container page-wrapper" style="padding-top:0;">

    <% if (typeof user !== 'undefined' && user && user.name && events && events.length > 0) { %>
        <div class="page-header">
            <h1>Upcoming Events</h1>
            <a href="/events" class="btn btn-ghost">View All <i class="fas fa-arrow-right"></i></a>
        </div>

        <div class="events-grid">
            <% events.forEach(function(event){ %>
                <div class="event-card animate-fade">
                    <img src="/uploads/<%= event.image %>" alt="<%= event.title %>" class="event-img"
                         onerror="this.src='https://images.unsplash.com/photo-1501281668745-f7f57925c3b4?auto=format&fit=crop&w=800&q=80'">
                    <div class="event-body">
                        <span class="event-tag"><%= event.category %></span>
                        <h3><%= event.title %></h3>
                        <div class="event-meta">
                            <span><i class="far fa-calendar"></i> <%= event.date.toDateString() %></span>
                            <span><i class="fas fa-map-marker-alt"></i> <%= event.location %></span>
                            <span><i class="fas fa-users"></i> <%= event.availableSeats %> seats left</span>
                        </div>
                        <a href="/events/<%= event._id %>" class="btn btn-primary" style="width:100%;">View Details</a>
                    </div>
                </div>
            <% }) %>
        </div>

    <% } else if (typeof user === 'undefined' || !user) { %>
        <!-- Not logged in — show feature highlights -->
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;margin-top:20px;">
            <div class="card animate-fade" style="padding:30px;text-align:center;">
                <div style="width:54px;height:54px;background:rgba(99,102,241,0.15);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.5rem;color:#6366f1;"><i class="fas fa-calendar-check"></i></div>
                <h3 style="margin-bottom:8px;">Browse Events</h3>
                <p style="font-size:0.875rem;color:var(--text-muted);">View all upcoming college events, workshops, and seminars.</p>
            </div>
            <div class="card animate-fade" style="padding:30px;text-align:center;animation-delay:0.1s;">
                <div style="width:54px;height:54px;background:rgba(6,182,212,0.15);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.5rem;color:#06b6d4;"><i class="fas fa-ticket-alt"></i></div>
                <h3 style="margin-bottom:8px;">Easy Registration</h3>
                <p style="font-size:0.875rem;color:var(--text-muted);">Register for events with one click and track from your dashboard.</p>
            </div>
            <div class="card animate-fade" style="padding:30px;text-align:center;animation-delay:0.2s;">
                <div style="width:54px;height:54px;background:rgba(245,158,11,0.15);border-radius:14px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.5rem;color:#f59e0b;"><i class="fas fa-star"></i></div>
                <h3 style="margin-bottom:8px;">Organize Events</h3>
                <p style="font-size:0.875rem;color:var(--text-muted);">Submit your own event proposals for admin review and approval.</p>
            </div>
        </div>
    <% } %>

</div>

<%- include('partials/footer') %>
