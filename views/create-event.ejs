<%- include('partials/header') %>

<div class="container page-wrapper">
    <div class="dash-layout">
        <aside class="sidebar animate-fade">
            <div class="sidebar-avatar">
                <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
                <h4><%= user.name %></h4>
                <p>Event Organizer</p>
            </div>
            <nav>
                <ul>
                    <li><a href="/dashboard"><i class="fas fa-ticket-alt"></i> My Registrations</a></li>
                    <li><a href="/user/profile"><i class="fas fa-user-edit"></i> Edit Profile</a></li>
                    <li><a href="/events"><i class="fas fa-search"></i> Browse Events</a></li>
                    <li><a href="/events/create" class="active"><i class="fas fa-plus-circle"></i> Organize Event</a></li>
                    <li><a href="/logout" class="danger"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                </ul>
            </nav>
        </aside>

        <div>
            <div class="page-header">
                <h1>Organize an Event</h1>
            </div>

            <div style="background:rgba(99,102,241,0.08);border:1px solid rgba(99,102,241,0.2);color:#a5b4fc;padding:12px 16px;border-radius:10px;margin-bottom:24px;font-size:0.875rem;">
                <i class="fas fa-info-circle"></i> Your event will be reviewed by the admin before going live.
            </div>

            <form action="/events/create" method="POST" enctype="multipart/form-data">

                <!-- Basic Info -->
                <div class="form-section">
                    <div class="form-section-title"><i class="fas fa-info-circle"></i> Basic Information</div>
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label>Event Title <span class="req">*</span></label>
                            <input type="text" name="title" required placeholder="e.g. Design Hackathon 2024">
                        </div>
                        <div class="form-group">
                            <label>Category <span class="req">*</span></label>
                            <select name="category" required>
                                <option value="">— Select —</option>
                                <option value="Workshop">Workshop</option>
                                <option value="Seminar">Seminar</option>
                                <option value="Concert">Concert</option>
                                <option value="Sports">Sports</option>
                                <option value="Cultural">Cultural</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Description <span class="req">*</span></label>
                        <textarea name="description" rows="4" required placeholder="Describe the highlights, agenda, and purpose of your event..."></textarea>
                    </div>
                </div>

                <!-- Date & Time -->
                <div class="form-section">
                    <div class="form-section-title"><i class="fas fa-clock"></i> Date & Time</div>
                    <div class="form-grid-3">
                        <div class="form-group">
                            <label>Event Date <span class="req">*</span></label>
                            <input type="date" name="date" required>
                        </div>
                        <div class="form-group">
                            <label>Start Time</label>
                            <input type="time" name="startTime">
                        </div>
                        <div class="form-group">
                            <label>End Time</label>
                            <input type="time" name="endTime">
                        </div>
                    </div>
                    <div class="form-group" style="max-width:300px;">
                        <label>Registration Deadline</label>
                        <input type="date" name="registrationDeadline">
                    </div>
                </div>

                <!-- Venue & Capacity -->
                <div class="form-section">
                    <div class="form-section-title"><i class="fas fa-map-marker-alt"></i> Venue & Capacity</div>
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label>Venue / Location <span class="req">*</span></label>
                            <input type="text" name="location" required placeholder="e.g. Science Block Room 204">
                        </div>
                        <div class="form-group">
                            <label>Maximum Participants <span class="req">*</span></label>
                            <input type="number" name="maxSeats" required placeholder="e.g. 100" min="1">
                        </div>
                    </div>
                </div>

                <!-- Contact -->
                <div class="form-section">
                    <div class="form-section-title"><i class="fas fa-user-tie"></i> Organizer & Contact</div>
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label>Organizer Name</label>
                            <input type="text" name="organizerName" placeholder="Your name or club name">
                        </div>
                        <div class="form-group">
                            <label>Speaker / Guest Name</label>
                            <input type="text" name="speakerName" placeholder="e.g. Chief Guest">
                        </div>
                    </div>
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label>Contact Email</label>
                            <input type="email" name="contactEmail" placeholder="your@email.com">
                        </div>
                        <div class="form-group">
                            <label>Contact Phone</label>
                            <input type="tel" name="contactPhone" placeholder="+91 98765 43210">
                        </div>
                    </div>
                </div>

                <!-- Banner -->
                <div class="form-section">
                    <div class="form-section-title"><i class="fas fa-image"></i> Event Banner</div>
                    <div class="form-group">
                        <label>Upload Poster <span style="color:var(--text-dim);font-size:0.75rem;">(JPG, PNG — max 5MB)</span></label>
                        <div class="file-upload-box" onclick="document.getElementById('eventImageInput').click()">
                            <i class="fas fa-cloud-upload-alt"></i>
                            <p>Click to upload event poster</p>
                            <span id="fileName">No file chosen</span>
                        </div>
                        <input type="file" id="eventImageInput" name="eventImage" accept="image/*" style="display:none;"
                               onchange="document.getElementById('fileName').textContent = this.files[0]?.name || 'No file chosen'">
                    </div>
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%;padding:16px;font-size:1rem;margin-top:8px;">
                    <i class="fas fa-paper-plane"></i> Submit for Review
                </button>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
